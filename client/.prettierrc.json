{
    "trailingComma": "es5",
    "semi": false,
    "tabWidth": 2,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "plugins": ["@ianvs/prettier-plugin-sort-imports"],
    "importOrder": [
      "^react$", 
      "",
      "<THIRD_PARTY_MODULES>",
      "",
      "^\\.\\./.*$",
      "",
      "^[.]",
      "",
      ".css$",
      "^(?!.*[.]css$)[./].*$"
    ]
  }